<svg viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <g id="dodecagon" transform="scale(1.2)">
      <polygon points="
        40,0 
        34.6,20 
        20,34.6 
        0,40 
        -20,34.6 
        -34.6,20 
        -40,0 
        -34.6,-20 
        -20,-34.6 
        0,-40 
        20,-34.6 
        34.6,-20" 
        fill="none" 
        stroke="black" 
        stroke-width="2" />
    </g>
  </defs>

  <g transform="translate(300, 200)">
    <polygon points="0,0 -20,80 20,80" fill="purple" />
    <g transform="rotate(20)">
      <rect x="-120" y="-8" width="240" height="16" fill="red" />
      <g transform="translate(-120, 0)">
        <use href="#dodecagon">
          <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="3s" repeatCount="indefinite" additive="sum" />
        </use>
      </g>
      <g transform="translate(120, 0)">
        <use href="#dodecagon">
          <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="3s" repeatCount="indefinite" additive="sum" />
        </use>
      </g>
    </g>
  </g>

  <g transform="translate(600, 180)">
    <polygon points="0,0 -15,70 15,70" fill="green" />
    <g transform="rotate(15)">
      <rect x="-90" y="-6" width="180" height="12" fill="red" />
      <g transform="translate(-90, 0)">
        <use href="#dodecagon" transform="scale(0.8)">
          <animateTransform attributeName="transform" type="rotate" from="0" to="-360" dur="2s" repeatCount="indefinite" additive="sum" />
        </use>
      </g>
      <g transform="translate(90, 0)">
        <use href="#dodecagon" transform="scale(0.8)">
          <animateTransform attributeName="transform" type="rotate" from="0" to="-360" dur="2s" repeatCount="indefinite" additive="sum" />
        </use>
      </g>
    </g>
  </g>

  <g transform="translate(450, 450)">
    <polygon points="0,0 -30,120 30,120" fill="blue" />
    <g transform="rotate(10)">
      <rect x="-150" y="-10" width="300" height="20" fill="red" />
      <g transform="translate(-150, 0)">
        <use href="#dodecagon" transform="scale(1.3)">
          <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="4s" repeatCount="indefinite" additive="sum" />
        </use>
      </g>
      <g transform="translate(150, 0)">
        <use href="#dodecagon" transform="scale(1.3)">
          <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="4s" repeatCount="indefinite" additive="sum" />
        </use>
      </g>
    </g>
  </g>
</svg>
